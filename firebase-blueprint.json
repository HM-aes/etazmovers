{
  "entities": {
    "Review": {
      "title": "Review",
      "description": "A customer review.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the reviewer."
        },
        "rating": {
          "type": "number",
          "description": "Rating from 1 to 5."
        },
        "text": {
          "type": "string",
          "description": "Review text."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the review was created."
        }
      },
      "required": ["name", "rating", "text", "createdAt"]
    },
    "Contact": {
      "title": "Contact",
      "description": "A contact form submission.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the sender."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email of the sender."
        },
        "message": {
          "type": "string",
          "description": "Message content."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the message was sent."
        }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "/reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "Customer reviews."
    },
    "/contacts/{contactId}": {
      "schema": { "$ref": "#/entities/Contact" },
      "description": "Contact form submissions."
    }
  }
}
